# Web frontend build-time config (copy to .env and fill in).

# Base URL of your deployed Cloudflare Worker (no trailing slash).
VITE_WORKER_URL=https://second-brain.<your-subdomain>.workers.dev

# Vite base path. For a project Pages site keep the default below.
# For a user/custom-domain site, set VITE_BASE=/
# VITE_BASE=/second-brain-varun-patkar/
