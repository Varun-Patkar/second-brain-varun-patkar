{
  "name": "@second-brain/worker",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Cloudflare Worker backend: agent orchestration + storage adapters for the second brain.",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "db:migrate:local": "wrangler d1 migrations apply second_brain --local",
    "db:migrate:remote": "wrangler d1 migrations apply second_brain --remote"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@second-brain/shared": "*",
    "agent-framework-js": "^1.1.1"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20240620.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0",
    "wrangler": "^3.60.0"
  }
}
